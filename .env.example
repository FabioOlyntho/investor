# InvestmentMonitor — Environment Variables
# Copy this file to .env and fill in your API keys.

# ─── AI Advisor ─────────────────────────────────────────────────
# Set at least ONE provider key to enable the AI Financial Advisor.

# Google Gemini (cheapest — ~$0.50/month)
GOOGLE_API_KEY=

# Anthropic Claude (best reasoning — ~$6-13/month)
ANTHROPIC_API_KEY=

# OpenAI GPT (good balance — ~$5-10/month)
OPENAI_API_KEY=

# ─── Optional: Override LLM provider/model ──────────────────────
# Default provider is "google" (Gemini Flash). Options: google, anthropic, openai
# ADVISOR_LLM_PROVIDER=google
# ADVISOR_LLM_MODEL=gemini-2.5-flash

# Separate provider/model for Q&A tab (defaults to same as main)
# ADVISOR_QA_PROVIDER=anthropic
# ADVISOR_QA_MODEL=claude-sonnet-4-20250514

# ─── Email ──────────────────────────────────────────────────────
# ALERT_EMAIL=fabio.olyntho@recodme.es
